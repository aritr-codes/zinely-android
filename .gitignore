# Keep the committed Gradle wrapper jar
!gradle/wrapper/gradle-wrapper.jar

# Kotlin
.kotlin/

# Dev scratch (commit message + PR body staging for the neutral runner workflow)
/tools/commitmsg.txt
/tools/prbody.txt

# jqwik failure-sample database (regenerated each test run)
.jqwik-database

# Editors / IDE (ignore the whole .idea directory)
/.idea/
.fleet/
.vscode/
Thumbs.db

# CodeGraph local index (developer tooling, not part of the source)
/.codegraph/

# Release signing — the key and its credentials never enter git (see docs/RELEASING.md).
# Losing the key means no future build can update an installed Zinely; back it up off-machine.
keystore.properties
*.jks
*.keystore
