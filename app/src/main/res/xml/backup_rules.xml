<?xml version="1.0" encoding="utf-8"?><!--
   Legacy auto-backup exclusions for API ≤30 (ignored on API 31+, which uses data_extraction_rules.xml).
   Privacy invariant (PRD §5, ADR-030): exclude every domain so no app data is ever auto-backed-up off
   device, belt-and-suspenders alongside android:allowBackup="false".
   See https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <exclude domain="root" path="." />
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
