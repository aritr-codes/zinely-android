# Normalize line endings: text files use LF in the repo.
* text=auto eol=lf

# Shell scripts and the Gradle wrapper must stay LF.
*.sh    text eol=lf
gradlew text eol=lf

# Windows scripts keep CRLF.
*.bat   text eol=crlf

# Binary assets — never normalize.
*.jar   binary
*.webp  binary
*.png   binary
*.jpg   binary
*.keystore binary
